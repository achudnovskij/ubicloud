#!/bin/env ruby
# frozen_string_literal: true

require_relative "../../common/lib/util"

# One-time post-installation. Create the ubi_admin database (guarded -- createdb is the
# one non-idempotent step), then apply tracked migrations (system roles, pgbouncer auth,
# ...) via the standalone, re-runnable migrate script, which can also be run independently
# to roll new migrations out to an existing server.
unless r("sudo -u postgres psql -tAc \"SELECT 1 FROM pg_database WHERE datname = 'ubi_admin'\"").include?("1")
  r "sudo -u postgres createdb ubi_admin"
end

r "sudo postgres/bin/migrate"

# AMI-provided init scripts for the postgres database. Kept as a plain (untracked) run for
# now; these will move into the migrate/ tree once the upstream migration mechanism lands.
Dir.glob("/var/cache/postgresql-init/*.sql").sort.each do |sql_file|
  r "sudo -u postgres psql -v 'ON_ERROR_STOP=1'", stdin: File.read(sql_file)
end
