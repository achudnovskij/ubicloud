#!/bin/env ruby
# frozen_string_literal: true

require_relative "../../common/lib/util"

# Applies pending SQL migrations. All applied migrations are tracked centrally in the
# ubi_admin database (ubi_admin.public.schema_migrations), keyed by folder-qualified path
# (e.g. /postgres/20260616_system_roles.sql, /ubi_admin/20260616_pgbouncer_auth.sql).
migrate_root = File.expand_path("../migrate", __dir__)
exit 0 unless File.directory?(migrate_root)

# Central tracking table in ubi_admin: create it and read the applied set once, up front.
r "sudo -u postgres psql -d ubi_admin -v 'ON_ERROR_STOP=1'", stdin: <<~SQL
  CREATE TABLE IF NOT EXISTS public.schema_migrations (
    filename   text PRIMARY KEY,
    applied_at timestamptz NOT NULL DEFAULT now()
  );
SQL
applied = r("sudo -u postgres psql -d ubi_admin -tAc 'SELECT filename FROM public.schema_migrations'").split("\n").map(&:strip)

# postgres first, then every other database directory in name order
ordered_dbs = (["postgres"] + Dir.children(migrate_root).sort).uniq

ordered_dbs.each do |db|
  dir = File.join(migrate_root, db)
  next unless File.directory?(dir)
  Dir.children(dir).select { |f| f.end_with?(".sql") }.sort.each do |name|
    key = "/#{db}/#{name}"
    next if applied.include?(key)
    # Apply the migration against its own database, then register it centrally in ubi_admin.
    r "sudo -u postgres psql -d #{db} -v 'ON_ERROR_STOP=1' --single-transaction", stdin: File.read(File.join(dir, name))
    r "sudo -u postgres psql -d ubi_admin -v 'ON_ERROR_STOP=1' -c \"INSERT INTO public.schema_migrations (filename) VALUES ('#{key}') ON CONFLICT (filename) DO NOTHING\""
  end
end
