{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "$id": "https://github.com/clickhouse/ubicloud/setup_config.schema.json",
  "title": "UbicloudSetupConfig",
  "description": "Schema for the YAML consumed by UbicloudSetup.run_ch_ubi (UBICLOUD_SETUP_YAML_PATH). Shared between the ubicloud setup.rb and the clickgres-platform helm chart values.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "enabled",
    "cleanup_default_locations",
    "email",
    "password",
    "project_name",
    "project_uuid",
    "locations"
  ],
  "properties": {
    "enabled": {
      "type": "boolean",
      "description": "When false, run_ch_ubi is a no-op."
    },
    "cleanup_default_locations": {
      "type": "boolean",
      "description": "When true, hide_default_locations is called to hide non-clickgres locations."
    },
    "email": {
      "type": "string",
      "format": "email",
      "minLength": 1
    },
    "password": {
      "type": "string",
      "minLength": 1
    },
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "project_uuid": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "locations": {
      "type": "array",
      "items": { "$ref": "#/definitions/LocationConfig" }
    },
    "pg_amis": {
      "type": "object",
      "description": "region -> postgres_version -> arch AMI map.",
      "additionalProperties": {
        "type": "object",
        "patternProperties": {
          "^pg[0-9]+$": { "$ref": "#/definitions/ArchAmiPair" }
        },
        "additionalProperties": false,
        "minProperties": 1
      }
    },
    "dns_server_amis": {
      "type": "object",
      "description": "region -> arch AMI map for DNS server VMs.",
      "additionalProperties": { "$ref": "#/definitions/ArchAmiPair" }
    },
    "bot_accounts": {
      "type": "object",
      "description": "logical name -> bot account.",
      "additionalProperties": { "$ref": "#/definitions/BotAccountConfig" }
    },
    "oidc_providers": {
      "type": "object",
      "description": "target UUID -> OIDC provider.",
      "propertyNames": {
        "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
      },
      "additionalProperties": { "$ref": "#/definitions/OidcProviderConfig" }
    }
  },
  "definitions": {
    "LocationConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["account_name", "name", "region", "role", "dns_suffix"],
      "properties": {
        "account_name": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "region": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z]{2}-[a-z]+-[0-9]+$"
        },
        "role": {
          "type": "string",
          "pattern": "^arn:aws:iam::[0-9]{12}:role/.+$"
        },
        "dns_suffix": { "type": "string", "minLength": 1 },
        "otel_otlp_destination": { "$ref": "#/definitions/OtelOtlpDestinationConfig" },
        "capacity_reservation": { "$ref": "#/definitions/CapacityReservationConfig" },
        "otel_otlp_export_endpoint": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "Deprecated. Retained for backward compatibility; ignored by setup.rb. Use otel_otlp_destination instead."
        }
      }
    },
    "CapacityReservationConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "description": "Standing AWS ODCR config; only applied when enabled is true.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "When false (default), no capacity reservation strand is created for the location."
        },
        "additional_capacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 2,
          "description": "Buffer fraction added on top of current usage (floored at +3 per instance type). Max mirrors Prog::CapacityReservation::MAX_ADDITIONAL_CAPACITY."
        },
        "enable_all_families": {
          "type": "boolean",
          "description": "Buffer every instance type currently in use; instance_families, if also set, adds its resolved sizes on top."
        },
        "allowed_capacity_decrease": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Buffer fraction to retain over current usage when shrinking (must be >= additional_capacity); omit/null means never shrink."
        },
        "reconcile_interval": {
          "type": "integer",
          "minimum": 60,
          "description": "Seconds between natural re-measure passes. Defaults to 300; floored at 60 to avoid hammering the AWS APIs."
        },
        "remove_orphaned_reservations": {
          "type": "boolean",
          "description": "If true, cancel managed ODCRs for instance types no longer eligible (e.g. removed from the config or a minimum_provisioned_* size that stopped being provisioned). When NOTHING is eligible it cancels ALL of the location's managed ODCRs (full wind-down), except during the InsufficientAZs safety path. Default false."
        },
        "instance_families": {
          "type": "object",
          "description": "family -> constraint (exactly one of minimum_cpu / minimum_storage / sizes / minimum_provisioned_cpu / minimum_provisioned_storage). The bare minimum_* and sizes cover all matching catalog sizes (pre-warming unused ones); the minimum_provisioned_* variants cover only matching sizes currently in use.",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "maxProperties": 1,
            "properties": {
              "minimum_cpu": { "type": "integer", "minimum": 1 },
              "minimum_storage": { "type": "integer", "minimum": 1 },
              "minimum_provisioned_cpu": { "type": "integer", "minimum": 1 },
              "minimum_provisioned_storage": { "type": "integer", "minimum": 1 },
              "sizes": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
            }
          }
        }
      }
    },
    "OtelOtlpDestinationConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["otlp_data_endpoint", "otlp_arrow_endpoint", "logs_endpoint", "metrics_endpoint", "auth_audience"],
      "properties": {
        "otlp_data_endpoint": { "type": "string", "format": "uri" },
        "otlp_arrow_endpoint": { "type": "string", "format": "uri" },
        "logs_endpoint": { "type": "string", "format": "uri" },
        "metrics_endpoint": { "type": "string", "format": "uri" },
        "auth_audience": { "type": "string" }
      }
    },
    "ArchAmiPair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["arch_x64", "arch_arm64"],
      "properties": {
        "arch_x64": { "$ref": "#/definitions/AmiId" },
        "arch_arm64": { "$ref": "#/definitions/AmiId" }
      }
    },
    "AmiId": {
      "type": "string",
      "pattern": "^ami-[0-9a-f]{8,17}$"
    },
    "BotAccountConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["email", "password"],
      "properties": {
        "email": { "type": "string", "format": "email", "minLength": 1 },
        "password": { "type": "string", "minLength": 1 }
      }
    },
    "OidcProviderConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display_name", "url", "client_id", "client_secret"],
      "properties": {
        "display_name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri", "pattern": "^https?://" },
        "client_id": { "type": "string", "minLength": 1 },
        "client_secret": { "type": "string", "minLength": 1 }
      }
    }
  }
}
